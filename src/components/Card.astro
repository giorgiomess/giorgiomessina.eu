---
import { ArrowUpRight, Lock } from 'lucide-react';

interface Props {
  title: string;
  subtitle: string;
  description: string;
  summary?: string;
  href?: string;
  unavailable?: boolean;
}

const { title, subtitle, description, summary, href, unavailable } = Astro.props;

const cardClass = "group relative flex flex-col p-6 bg-white rounded-2xl border border-slate-200 shadow-sm transition-all duration-300";
const interactiveClass = "hover:shadow-lg hover:shadow-orange-500/10 hover:border-orange-300 hover:-translate-y-1";
---

{unavailable ? (
  <div class={cardClass}>
    <div class="absolute top-6 right-6 text-slate-300">
      <Lock className="w-5 h-5" />
    </div>

    <h3 class="text-xl font-bold text-slate-800 mb-2 pr-6">
      {title}
    </h3>

    <div class="mb-4 flex-grow">
      <p class="text-slate-500 text-sm font-medium">{subtitle}</p>
      {summary && <p class="text-slate-500 text-sm mt-2">{summary}</p>}
    </div>

    <div class="mt-auto pt-4 border-t border-slate-100 flex items-center justify-between gap-3 flex-wrap">
      <span class="inline-flex items-center px-2.5 py-0.5 rounded-md text-xs font-medium bg-orange-50 text-orange-700 border border-orange-100">
        {description}
      </span>
      <span class="inline-flex items-center gap-1 text-xs font-medium text-slate-400">
        <Lock className="w-3 h-3" /> Slides not available for public release
      </span>
    </div>
  </div>
) : (
  <a
    href={href}
    target="_blank"
    rel="noopener noreferrer"
    class={`${cardClass} ${interactiveClass}`}
  >
    <div class="absolute top-6 right-6 text-orange-400 opacity-0 transform translate-x-2 group-hover:opacity-100 group-hover:translate-x-0 transition-all duration-300">
      <ArrowUpRight className="w-5 h-5" />
    </div>

    <h3 class="text-xl font-bold text-slate-800 mb-2 group-hover:text-orange-600 transition-colors pr-6">
      {title}
    </h3>

    <div class="mb-4 flex-grow">
      <p class="text-slate-500 text-sm font-medium">{subtitle}</p>
      {summary && <p class="text-slate-500 text-sm mt-2">{summary}</p>}
    </div>

    <div class="mt-auto pt-4 border-t border-slate-100">
      <span class="inline-flex items-center px-2.5 py-0.5 rounded-md text-xs font-medium bg-orange-50 text-orange-700 border border-orange-100">
        {description}
      </span>
    </div>
  </a>
)}
